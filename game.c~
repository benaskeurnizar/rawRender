void GameInit(int width,int height,Engine** engine){
  *engine = (Engine*)malloc(sizeof(Engine));
  memset(&((*engine)->input),0,sizeof(InputState));
  (*engine)->first = 0;
  (*engine)->refresh_rate_hz = 45; // frame per secons
  (*engine)->debug_mode = 0;
  //TODO: Create the renderer
  (*engine)->renderer.screenWidth = width;
  (*engine)->renderer.screenHeight = height;
  (*engine)->renderer.render_time = 0.0;
  (*engine)->renderer.clip_time = 0.0;
  (*engine)->renderer.calc_time = 0.0;
  float fovy_rad = 60.0 * (M_PI/180.0f);
  float aspect = (float)width / (float)height;
  createProj(fovy_rad,aspect,0.1,1000.0,(*engine)->renderer.proj);
  //TODO: Create the world (for now the camera),also make a simple mesh
  InitCamera(*engine,(vec3){0.0,0.0,0.0},90.0,0.0);
  //createSimpleMesh(*engine);
  //E://Rendering//Folder//rendering//bunny.obj
  //E://2.5DIM//3DLines//objects//f.obj
  (*engine)->world.meshes = create_mesh_from_object("E://2.5DIM//3DLines//objects//f.obj");
  (*engine)->world.mesh =  create_pyramid();
  //(*engine)->world.num_meshes = 1;
  mesh_to_meshs((*engine)->world.meshes,&(*engine)->world.mesh);
  (*engine)->input.firstMousePress = 1;
}

