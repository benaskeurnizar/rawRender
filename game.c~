void InitCamera(Engine* engine,vec3 pos,float yaw,float pitch){
  (engine)->world.camera.pitch = pitch;
  (engine)->world.camera.yaw = yaw;
  vec3 world_up = {0.0,1.0,0.0};
  vec3 cameraPos = {0.0,0.0,-10.0};
  vec3_copy(cameraPos,(engine)->world.camera.pos);
  vec3 lookDir = {0.0,0.0,1.0};
  vec3_copy(lookDir,(engine)->world.camera.lookdir);
  vec3 target;
  vec3_add(cameraPos,lookDir,target);
  mat4 m;
  mat4_pointAt(cameraPos,target,(vec3){0.0f,1.0f,0.0f},m);
  mat4_quickInverse(m,(engine)->world.camera.view);
}

float MyRadians(float angle) {
  vec3 vc;
  float result = (angle * M_PI) / 180.0;
  return result;
}

void UpdateCamera(Engine* engine){
  float forward_sensitivity =0.3;
  float right_sensitivity = 0.3;
  float DForward = 0.0;
  float DRight = 0.0;
  int cameraUpdated = 0;
  if(engine->input.keyW){
    DForward = forward_sensitivity;
  }else if(engine->input.keyS){
    DForward = -forward_sensitivity;
  }
  if(engine->input.keyS && engine->input.keyW){
    DForward = 0.0f;
  }

  if(engine->input.keyD){
    DRight = right_sensitivity;
  }else if(engine->input.keyA){
    DRight = -right_sensitivity;
  }
  if(engine->input.keyA && engine->input.keyD){
    DRight = 0.0;
  }
  
  float frametime = 1.0f / 30.0f;   // ≈ 0.0333333f
  float fmove = DForward ;float smove = DRight;
  float sensitivity = 0.05;
  engine->world.camera.yaw   += engine->input.DYaw;
  engine->world.camera.pitch += engine->input.DPitch;

  // Constrain pitch
  if ( engine->world.camera.pitch > 89.0f)
     engine->world.camera.pitch = 89.0f;
  if ( engine->world.camera.pitch < -89.0f)
     engine->world.camera.pitch = -89.0f;
  
  // Move along camera's actual forward/right directions
  vec3 front;
  float yawRad = MyRadians(engine->world.camera.yaw);
  float pitchRad = MyRadians(engine->world.camera.pitch);

  front[0] = cosf(yawRad) * cosf(pitchRad);
  front[1] = sinf(pitchRad);
  front[2] = sinf(yawRad) * cosf(pitchRad);
  vec3_normalize(front);
  vec3_copy(front,  engine->world.camera.lookdir);
  vec3 right;
  vec3 up = {0,1,0};
  vec3_cross(front, up, right);
  vec3_normalize(right);
  engine->world.camera.pos[0] += front[0]*DForward + right[0]*DRight;
  engine->world.camera.pos[1] += front[1]*DForward;  // or 0 if you want no vertical movement
  engine->world.camera.pos[2] += front[2]*DForward + right[2]*DRight;

  //engine->world.camera.pos[2] -= engine->player.mins[2];
  

  vec3 target;
  vec3_add(engine->world.camera.pos,engine->world.camera.lookdir,target);
  mat4 m;
  mat4_pointAt(engine->world.camera.pos,target,(vec3){0.0f,1.0f,0.0f},m);
  mat4_quickInverse(m,(engine)->world.camera.view);

  engine->input.DYaw = 0.0;
  engine->input.DPitch = 0.0;
}

void createSimpleMesh(Engine* engine){
  engine->world.num_meshes = 1;
  engine->world.meshes = (Mesh*)malloc(sizeof(Mesh));

  Mesh *cube = &engine->world.meshes[0];

  cube->num_triangles = 12;
  cube->Triangles = (Triangle*)malloc(sizeof(Triangle) * 12);

  float s = 2.0f;

  vec3 v[8] = {
    {-s, -s, -s}, // 0
    { s, -s, -s}, // 1
    { s,  s, -s}, // 2
    {-s,  s, -s}, // 3
    {-s, -s,  s}, // 4
    { s, -s,  s}, // 5
    { s,  s,  s}, // 6
    {-s,  s,  s}  // 7
  };

  
  // Front
  vec3_copy((vec3){-s,-s,-s}, cube->Triangles[0].pt1);
  vec3_copy((vec3){ s,-s,-s}, cube->Triangles[0].pt2);
  vec3_copy((vec3){ s, s,-s}, cube->Triangles[0].pt3);

  vec3_copy((vec3){-s,-s,-s}, cube->Triangles[1].pt1);
  vec3_copy((vec3){ s, s,-s}, cube->Triangles[1].pt2);
  vec3_copy((vec3){-s, s,-s}, cube->Triangles[1].pt3);

  // Back
  vec3_copy((vec3){ s,-s, s}, cube->Triangles[2].pt1);
  vec3_copy((vec3){-s,-s, s}, cube->Triangles[2].pt2);
  vec3_copy((vec3){-s, s, s}, cube->Triangles[2].pt3);

  vec3_copy((vec3){ s,-s, s}, cube->Triangles[3].pt1);
  vec3_copy((vec3){-s, s, s}, cube->Triangles[3].pt2);
  vec3_copy((vec3){ s, s, s}, cube->Triangles[3].pt3);

  // Left
  vec3_copy((vec3){-s,-s, s}, cube->Triangles[4].pt1);
  vec3_copy((vec3){-s,-s,-s}, cube->Triangles[4].pt2);
  vec3_copy((vec3){-s, s,-s}, cube->Triangles[4].pt3);

  vec3_copy((vec3){-s,-s, s}, cube->Triangles[5].pt1);
  vec3_copy((vec3){-s, s,-s}, cube->Triangles[5].pt2);
  vec3_copy((vec3){-s, s, s}, cube->Triangles[5].pt3);

  // Right
  vec3_copy((vec3){ s,-s,-s}, cube->Triangles[6].pt1);
  vec3_copy((vec3){ s,-s, s}, cube->Triangles[6].pt2);
  vec3_copy((vec3){ s, s, s}, cube->Triangles[6].pt3);

  vec3_copy((vec3){ s,-s,-s}, cube->Triangles[7].pt1);
  vec3_copy((vec3){ s, s, s}, cube->Triangles[7].pt2);
  vec3_copy((vec3){ s, s,-s}, cube->Triangles[7].pt3);

  // Bottom
  vec3_copy((vec3){-s,-s, s}, cube->Triangles[8].pt1);
  vec3_copy((vec3){ s,-s, s}, cube->Triangles[8].pt2);
  vec3_copy((vec3){ s,-s,-s}, cube->Triangles[8].pt3);

  vec3_copy((vec3){-s,-s, s}, cube->Triangles[9].pt1);
  vec3_copy((vec3){ s,-s,-s}, cube->Triangles[9].pt2);
  vec3_copy((vec3){-s,-s,-s}, cube->Triangles[9].pt3);

  // Top
  vec3_copy((vec3){-s, s,-s}, cube->Triangles[10].pt1);
  vec3_copy((vec3){ s, s,-s}, cube->Triangles[10].pt2);
  vec3_copy((vec3){ s, s, s}, cube->Triangles[10].pt3);

  vec3_copy((vec3){-s, s,-s}, cube->Triangles[11].pt1);
  vec3_copy((vec3){ s, s, s}, cube->Triangles[11].pt2);
  vec3_copy((vec3){-s, s, s}, cube->Triangles[11].pt3);

  mat4_identity(cube->model);
}
